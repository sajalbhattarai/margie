${BOLD}USAGE${NC}
  ./annotate-genome [MODE] [OPTIONS]

${BOLD}QUICK START${NC}
  ./annotate-genome --interactive     Guided first-time setup + annotation wizard
  ./annotate-genome --run             Auto-annotate everything in input/
