#!/usr/bin/env bash
# annotate-genome
# Margie — Complete genome functional annotation pipeline wrapper.
# Supports single-genome, batch, interactive, and SLURM submission modes.
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# ── Default paths ─────────────────────────────────────────────────────────────
DEFAULT_INPUT_DIR="$SCRIPT_DIR/input"
DEFAULT_OUTPUT_DIR="$SCRIPT_DIR/output"
LOG_DIR="$SCRIPT_DIR/logs"
CONTAINERS_DIR="$SCRIPT_DIR/processing/containers"
STATE_DIR="$SCRIPT_DIR/.margie_state"
STATE_CONTAINERS_FILE="$STATE_DIR/containers.ready"
STATE_DATABASES_FILE="$STATE_DIR/databases.ready"

INPUT_DIR="$DEFAULT_INPUT_DIR"

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

# ── Pipeline parameters ───────────────────────────────────────────────────────
INPUT_FASTA=""
OUTPUT_DIR="$DEFAULT_OUTPUT_DIR"
DB_SELECTION="all"
NODES=""
TASKS=1
THREADS=""
USE_SLURM=0
SLURM_ACCOUNT=""
SLURM_PARTITION=""
CONTAINER_RUNTIME=""
PIPELINE_REDO=0
DRY_RUN_PIPELINE=0
NON_INTERACTIVE=0
WANT_GUI=""
_MODE=""
RUN_SCORING=0
RUN_PULS=0
RUN_SYNTENY=0
RASTTK_RUN_MODE="full"

# ── Tool catalogue ─────────────────────────────────────────────────────────────
ALL_DB_TOOLS=(cog pfam tigrfam kegg dbcan eggnog merops tcdb uniprot interpro rasttk operon)
ALL_PIPELINE_STEPS=(prodigal cog pfam tigrfam kegg dbcan eggnog merops tcdb uniprot interpro rasttk operon consolidation synteny)
GENE_CALLER_TOOLS=(prodigal rasttk)
RUN_SELECTED_TOOLS=()

