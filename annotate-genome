  --setup             First-time container and database setup only
  --preflight         Check environment readiness AND pipeline readiness, then exit
  --menu              Open the advanced interactive menu

${BOLD}INPUT / OUTPUT${NC}
    --input PATH, -input PATH
                                            Generic input path. If PATH is a file it is treated as
                                            --input-fasta; if PATH is a directory it is treated as
                                            --input-dir.
  --input-fasta FILE, -f FILE
                      Path to a single genome FASTA (.fna/.fasta/.fa) or
