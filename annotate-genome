# ════════════════════════════════════════════════════════════════════════════════
#  UTILITY HELPERS
# ════════════════════════════════════════════════════════════════════════════════
ncpus() { nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4; }

effective_nodes()   { if [[ -n "$NODES" ]]; then echo "$NODES"; else ncpus; fi; }
effective_threads() {
    if [[ -n "$THREADS" ]]; then
        echo "$THREADS"
    else
        local n; n="$(effective_nodes)"
        echo $(( n / TASKS > 0 ? n / TASKS : 1 ))
    fi
}

run_preflight() { bash "$SCRIPT_DIR/setup_containers.sh" --preflight; }
run_setup()     { bash "$SCRIPT_DIR/setup_containers.sh" "$@"; }

setup_recorded_complete() {
    [[ -f "$STATE_CONTAINERS_FILE" && -f "$STATE_DATABASES_FILE" ]]
}

record_setup_markers_from_readiness() {
    mkdir -p "$STATE_DIR"
    if [[ ! -f "$STATE_CONTAINERS_FILE" ]]; then
        {
            printf 'timestamp=%s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
            printf 'source=annotate-genome-readiness\n'
        } > "$STATE_CONTAINERS_FILE"
    fi
    if [[ ! -f "$STATE_DATABASES_FILE" ]]; then
        {
            printf 'timestamp=%s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
            printf 'source=annotate-genome-readiness\n'
        } > "$STATE_DATABASES_FILE"
    fi
}

detect_os() {
    case "$(uname -s 2>/dev/null || echo unknown)" in
        Darwin) echo "macos" ;;
        Linux)  echo "linux" ;;
        *)      echo "other" ;;
    esac
}

is_setup_flag() {
    case "$1" in
        --skip-db|--db|-all|all|--dry-run|--platform|--gui) return 0 ;;
        *) return 1 ;;
    esac
}

append_selected_run_tool() {
    local tool_name="$1"
    local existing
    for existing in "${RUN_SELECTED_TOOLS[@]-}"; do
        [[ "$existing" == "$tool_name" ]] && return 0
    done
    RUN_SELECTED_TOOLS+=("$tool_name")
}

prompt_yes_no() {
    local prompt="$1" default_ans="${2:-y}" ans
    if [[ "${NON_INTERACTIVE:-0}" -eq 1 ]]; then
        ans="$default_ans"
    elif [[ "$default_ans" == "y" ]]; then
        read -r -p "$prompt [Y/n]: " ans; ans="${ans:-y}"
    else
        read -r -p "$prompt [y/N]: " ans; ans="${ans:-n}"
    fi
    [[ "$ans" =~ ^[Yy]$ ]]
}

