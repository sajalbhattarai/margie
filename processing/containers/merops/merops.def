Bootstrap: docker
From: ubuntu:22.04

%labels
    maintainer "Bioinformatics Pipeline"
    description "MEROPS peptidase annotation using Diamond"
    version "1.0"

%environment
    export DEBIAN_FRONTEND=noninteractive

%post
    apt-get update && apt-get install -y \
        diamond-aligner \
        python3 \
        python3-pip \
        wget \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*
    mkdir -p /container/input /container/output /container/db /container/scripts

%files
    scripts/ /container/scripts/

%post
    find /container/scripts -maxdepth 1 -type f -name "*.sh" -exec chmod +x {} \;

%runscript
    exec /bin/bash "$@"
