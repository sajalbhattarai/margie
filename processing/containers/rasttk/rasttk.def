Bootstrap: docker
From: ubuntu:22.04

%labels
    maintainer "BV-BRC RASTtk Container"
    description "BV-BRC RASTtk container for gene calling and functional annotation"
    version "1.0"

%environment
    export DEBIAN_FRONTEND=noninteractive
    export PATH="/container/scripts:${PATH}"

%post
    apt-get update && apt-get install -y \
        wget \
        curl \
        python3 \
        python3-pip \
        git \
        less \
        vim \
        nano \
        ca-certificates \
        build-essential \
        && rm -rf /var/lib/apt/lists/*
    cd /tmp && \
        wget -q https://github.com/BV-BRC/BV-BRC-CLI/releases/download/1.040/bvbrc-cli-1.040.deb && \
        apt-get update && \
        apt-get install -y ./bvbrc-cli-1.040.deb && \
        rm bvbrc-cli-1.040.deb && \
        rm -rf /var/lib/apt/lists/*
    mkdir -p /container/scripts /container/db /container/input /container/output

%files
    scripts/ /container/scripts/

%post
    find /container/scripts -maxdepth 1 -type f -name "*.sh" -exec chmod +x {} \;

%runscript
    exec /bin/bash "$@"
