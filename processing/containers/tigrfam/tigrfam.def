Bootstrap: docker
From: ubuntu:22.04

%labels
    maintainer "Bioinformatics Pipeline"
    description "TIGRfam annotation using HMMER 3.4"
    version "1.0"

%environment
    export DEBIAN_FRONTEND=noninteractive

%post
    apt-get update && apt-get install -y \
        wget \
        tar \
        gzip \
        make \
        gcc \
        g++ \
        perl \
        python3 \
        python3-pip \
        bc \
        && rm -rf /var/lib/apt/lists/*
    cd /tmp && \
        wget http://eddylab.org/software/hmmer/hmmer-3.4.tar.gz && \
        tar -xzf hmmer-3.4.tar.gz && \
        cd hmmer-3.4 && \
        ./configure && \
        make -j$(nproc) && \
        make install && \
        cd / && \
        rm -rf /tmp/hmmer-3.4*
    mkdir -p /container/input /container/output /container/db /container/scripts

%files
    scripts/run_hmmscan.sh /container/scripts/run_hmmscan.sh
    scripts/consolidate_tigrfam.py /container/scripts/consolidate_tigrfam.py

%post
    find /container/scripts -maxdepth 1 -type f -name "*.sh" -exec chmod +x {} \;

%runscript
    exec /bin/bash "$@"
